// Ташқи ҳисобот: "Товарлар кирими" — Товар (қаторлар) / Сана (устунлар) матрицаси.
// Чиқиш кўриниши расмдагидек:  №  Товар  Дата1  Дата2  ...        охирги қатор — Итого

Функция ТекстКалит(Товар, Сана)
	Возврат Строка(Товар.УникальныйИдентификатор()) + "_" + Формат(Сана, "ДФ=yyyyMMddHHmmss");
КонецФункции

Процедура Сформировать(ТабДок) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТоварларРегистрыНакопления.Период КАК Сана,
	|	ТоварларРегистрыНакопления.Товар КАК Товар,
	|	СУММА(ТоварларРегистрыНакопления.Сони) КАК Сони
	|ИЗ
	|	РегистрНакопления.ТоварларРегистрыНакопления КАК ТоварларРегистрыНакопления
	|ГДЕ
	|	ТоварларРегистрыНакопления.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|СГРУППИРОВАТЬ ПО
	|	ТоварларРегистрыНакопления.Период,
	|	ТоварларРегистрыНакопления.Товар
	|УПОРЯДОЧИТЬ ПО
	|	Товар,
	|	Сана";

	Данные = Запрос.Выполнить().Выгрузить();

	// --- Уникал товарлар ва саналар рўйхати + "Товар+Сана -> Сони" харитаси ---
	Товарлар = Новый СписокЗначений;
	Саналар  = Новый СписокЗначений;
	Харита   = Новый Соответствие;

	Для Каждого Стр Из Данные Цикл
		Если Товарлар.НайтиПоЗначению(Стр.Товар) = Неопределено Тогда
			Товарлар.Добавить(Стр.Товар, Строка(Стр.Товар));
		КонецЕсли;
		Если Саналар.НайтиПоЗначению(Стр.Сана) = Неопределено Тогда
			Саналар.Добавить(Стр.Сана, Формат(Стр.Сана, "ДФ=dd.MM.yyyy"));
		КонецЕсли;
		Харита.Вставить(ТекстКалит(Стр.Товар, Стр.Сана), Стр.Сони);
	КонецЦикла;

	Товарлар.СортироватьПоПредставлению();
	Саналар.СортироватьПоЗначению();

	КолонкаОхир = 2 + Саналар.Количество(); // 1-№, 2-Товар, 3..N - саналар

	ТабДок.Очистить();
	ТабДок.ФиксацияСверху = 1;

	Шрифт_Калин = Новый Шрифт(, , Истина);
	Линия_Тонкая = ЛинияРисункаТабличногоДокумента.Тонкая;

	// --- 1-қатор: Шапка ---
	СтрШапка = 1;
	ТабДок.Область(СтрШапка, 1).Текст = "№";
	ТабДок.Область(СтрШапка, 2).Текст = "Товар";

	Кол = 3;
	Для Каждого ЭлемСана Из Саналар Цикл
		ТабДок.Область(СтрШапка, Кол).Текст = ЭлемСана.Представление;
		Кол = Кол + 1;
	КонецЦикла;

	ОбластьШапка = ТабДок.Область(СтрШапка, 1, СтрШапка, КолонкаОхир);
	ОбластьШапка.Шрифт = Шрифт_Калин;
	ОбластьШапка.ГоризонтальноеПоложение = ГоризонтальноеПоложениеТекста.Центр;
	ОбластьШапка.ЦветФона = Новый Цвет(224, 224, 224);
	Для К = 1 По КолонкаОхир Цикл
		ТабДок.Область(СтрШапка, К).Обвести(Линия_Тонкая, Линия_Тонкая, Линия_Тонкая, Линия_Тонкая);
	КонецЦикла;

	// --- Товар қаторлари ---
	ИтогПоКолонкам = Новый Массив;
	Для Индекс = 1 По Саналар.Количество() Цикл
		ИтогПоКолонкам.Добавить(0);
	КонецЦикла;

	ТекСтрока = СтрШапка;
	НомерСтроки = 1;

	Для Каждого ЭлемТовар Из Товарлар Цикл
		ТекСтрока = ТекСтрока + 1;

		ТабДок.Область(ТекСтрока, 1).Текст = НомерСтроки;
		ТабДок.Область(ТекСтрока, 2).Текст = ЭлемТовар.Представление;

		Кол = 3;
		Индекс = 1;
		Для Каждого ЭлемСана Из Саналар Цикл
			Калит = ТекстКалит(ЭлемТовар.Значение, ЭлемСана.Значение);
			Сони = Харита[Калит];
			Если Сони = Неопределено Тогда
				Сони = 0;
			КонецЕсли;
			Если Сони <> 0 Тогда
				ТабДок.Область(ТекСтрока, Кол).Текст = Сони;
				ТабДок.Область(ТекСтрока, Кол).ГоризонтальноеПоложение = ГоризонтальноеПоложениеТекста.Центр;
			КонецЕсли;
			ИтогПоКолонкам[Индекс - 1] = ИтогПоКолонкам[Индекс - 1] + Сони;
			Кол = Кол + 1;
			Индекс = Индекс + 1;
		КонецЦикла;

		Для К = 1 По КолонкаОхир Цикл
			ТабДок.Область(ТекСтрока, К).Обвести(Линия_Тонкая, Линия_Тонкая, Линия_Тонкая, Линия_Тонкая);
		КонецЦикла;

		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;

	// --- Итого қатори ---
	ТекСтрока = ТекСтрока + 1;
	ОбластьИтогоЁрлик = ТабДок.Область(ТекСтрока, 1, ТекСтрока, 2);
	ОбластьИтогоЁрлик.Объединить();
	ОбластьИтогоЁрлик.Текст = "Итого";

	Кол = 3;
	Для Индекс = 1 По ИтогПоКолонкам.Количество() Цикл
		ТабДок.Область(ТекСтрока, Кол).Текст = ИтогПоКолонкам[Индекс - 1];
		ТабДок.Область(ТекСтрока, Кол).ГоризонтальноеПоложение = ГоризонтальноеПоложениеТекста.Центр;
		Кол = Кол + 1;
	КонецЦикла;

	ОбластьИтого = ТабДок.Область(ТекСтрока, 1, ТекСтрока, КолонкаОхир);
	ОбластьИтого.Шрифт = Шрифт_Калин;
	Для К = 1 По КолонкаОхир Цикл
		ТабДок.Область(ТекСтрока, К).Обвести(Линия_Тонкая, Линия_Тонкая, Линия_Тонкая, Линия_Тонкая);
	КонецЦикла;

	// Устун кенгликлари
	ТабДок.Область(, 1).Ширина = 5;
	ТабДок.Область(, 2).Ширина = 20;
	Для К = 3 По КолонкаОхир Цикл
		ТабДок.Область(, К).Ширина = 12;
	КонецЦикла;

КонецПроцедуры
