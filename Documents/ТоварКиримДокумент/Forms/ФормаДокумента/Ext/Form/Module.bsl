&НаКлиенте
Функция РасчетСумма();
	ТС = Элементы.Руйхат.ТекущиеДанные;
	ТС.Суммаси = ТС.Сони * ТС.Нархи;
	
	ЖамиСумма = 0;
	Для Каждого Строка Из Объект.Руйхат Цикл
		ЖамиСумма = ЖамиСумма + Строка.Суммаси;
	КонецЦикла;
	
	Объект.ЖамиСумма = ЖамиСумма;
КонецФункции // ()


&НаКлиенте
Процедура РуйхатСониПриИзменении(Элемент)
	РасчетСумма();	
КонецПроцедуры


&НаКлиенте
Процедура РуйхатНархиПриИзменении(Элемент)
	РасчетСумма();
КонецПроцедуры

